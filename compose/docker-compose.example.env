# HomeCore — Plantilla de variables de entorno
# ─────────────────────────────────────────────────────────────────
# Copia este fichero a .env y rellena los valores reales.
# El fichero .env NUNCA se sube a GitHub (está en .gitignore).
#
#   cp docker-compose.example.env .env
#   nano .env
# ─────────────────────────────────────────────────────────────────


# ── Dominio ───────────────────────────────────────────────────────
# Dominio base configurado en Cloudflare (sin subdominio)
# Los subdominios (auth., homecore., files...) se añaden en el Caddyfile
DOMINIO=theikaz.com


# ── Authentik — clave secreta ─────────────────────────────────────
# Cadena aleatoria larga. Genera una con:
#   openssl rand -hex 32
AUTHENTIK_SECRET_KEY=


# ── Authentik — base de datos ─────────────────────────────────────
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik
# Contraseña de la base de datos. Genera una con:
#   openssl rand -hex 16
AUTHENTIK_DB_PASSWORD=


# ── Authentik — credenciales del primer admin ─────────────────────
# Solo se aplican en el primer arranque. Después se gestionan desde la UI.
AUTHENTIK_BOOTSTRAP_EMAIL=admin@tudominio.com
AUTHENTIK_BOOTSTRAP_PASSWORD=


# ── Cloudflare Tunnel ─────────────────────────────────────────────
# Token generado en el panel de Cloudflare: Zero Trust > Tunnels
# Dejar vacío (o comentar el servicio cloudflared) hasta tenerlo
CLOUDFLARE_TUNNEL_TOKEN=


